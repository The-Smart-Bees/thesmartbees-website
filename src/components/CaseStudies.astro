---
const caseStudies = [
  {
    tag: "Client Project",
    title: "Industrial Jewelry Manufacturer",
    metric: "$750K+",
    metricLabel: "in operational savings",
    challenge: "A gold and silver jewelry manufacturer was managing their database, logistics, inventory, client relationships, and product catalogs through disconnected manual processes. Every department relied on spreadsheets and manual coordination. Growth was capped by how many hours the team could physically work.",
    solution: "We built a comprehensive automation suite connecting every department: centralized database, automated logistics tracking, ERP workflows, CRM pipelines, and dynamic product catalogs that update with images and pricing in real time.",
    result: "Over $750K in operational savings by eliminating manual coordination across departments. The team shifted from data management to design and client strategy. What used to take days now runs autonomously.",
  },
  {
    tag: "Our Own Systems",
    title: "Automated B2B Sales Pipeline",
    metric: "$1M+",
    metricLabel: "in closed revenue",
    challenge: "Before building systems for clients, we faced the same problem ourselves: B2B sales required constant manual prospecting, follow-ups, and pipeline management. Every new deal meant more hours.",
    solution: "We built the same lead generation systems we now deploy for clients: automated prospect identification, data enrichment, personalized outreach sequences, and pipeline tracking — running continuously.",
    result: "Over $1M in B2B revenue closed through these systems. We share this not as a client case study, but as proof that we use what we sell. These systems run our own business every day.",
  },
];
---

<section id="case-studies" class="py-20 md:py-28 bg-bg-soft">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 fade-in">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary">Proof It Works</h2>
    </div>
    <div class="space-y-8 fade-in-stagger">
      {caseStudies.map((cs) => (
        <div class="fade-in bg-white border border-border rounded-2xl p-8 md:p-10">
          <div class="flex flex-col md:flex-row md:items-start gap-8">
            <div class="md:w-1/3 shrink-0">
              <span class="inline-block text-xs font-medium text-text-tertiary border border-border px-3 py-1 rounded-full uppercase tracking-wider">{cs.tag}</span>
              <h3 class="text-xl md:text-2xl font-bold text-text-primary mt-3">{cs.title}</h3>
              <div class="mt-4">
                <span class="text-4xl md:text-5xl font-extrabold text-text-primary">{cs.metric}</span>
                <p class="text-sm text-text-tertiary mt-1">{cs.metricLabel}</p>
              </div>
            </div>
            <div class="md:w-2/3 space-y-6">
              <div>
                <p class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">The Challenge</p>
                <p class="text-text-secondary leading-relaxed">{cs.challenge}</p>
              </div>
              <div>
                <p class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">What We Built</p>
                <p class="text-text-secondary leading-relaxed">{cs.solution}</p>
              </div>
              <div>
                <p class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">The Result</p>
                <p class="text-text-secondary leading-relaxed">{cs.result}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
