---
const services = [
  {
    title: "Lead Generation",
    headline: "A pipeline that fills itself while your team focuses on closing.",
    description: "Finding the right prospects takes time your sales team doesn't have. We build systems that identify ideal buyers, enrich their data, score them against your criteria, and run personalized outreach — around the clock, without manual effort.",
    features: [
      "Prospect identification matched to your ideal customer profile",
      "Lead scoring and qualification before they reach your CRM",
      "Personalized outreach sequences that read like a human wrote them",
      "Consistent pipeline flow without adding headcount",
    ],
  },
  {
    title: "Business Automation",
    headline: "Reclaim the hours your team loses to repetitive work.",
    description: "Data entry, reporting, inventory updates, invoice processing — these tasks eat hours and add zero strategic value. We map your workflows, find the bottlenecks, and build systems that handle them accurately and at scale.",
    features: [
      "End-to-end workflow automation across departments",
      "CRM, ERP, and database integrations that actually talk to each other",
      "AI-powered document and data processing",
      "Systems that grow with your business",
    ],
  },
];
---

<section id="services" class="py-20 md:py-28 border-t border-border">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 fade-in">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary">What We Build</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 fade-in-stagger">
      {services.map((service) => (
        <div class="fade-in border border-border rounded-2xl p-8 hover:shadow-md transition-all duration-300">
          <p class="text-sm font-semibold text-text-tertiary uppercase tracking-wider mb-3">{service.title}</p>
          <h3 class="text-xl md:text-2xl font-bold text-text-primary mb-4">{service.headline}</h3>
          <p class="text-text-secondary leading-relaxed mb-6">{service.description}</p>
          <ul class="space-y-3">
            {service.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-text-secondary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent-green shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
